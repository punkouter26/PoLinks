{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.SemanticKernel": "Information"
    }
  },
  "AzureStorage": {
    "ConnectionString": "UseDevelopmentStorage=true"
  },
  "AzureAI": {
    "ModelId": "gpt-4.1-nano",
    "Language": {
      "Endpoint": "",
      "ApiKey": ""
    }
  },
  "Bluesky": {
    "ApiBaseUrl": "https://bsky.social",
    "JetstreamUrl": "wss://jetstream2.us-east.bsky.network/subscribe",
    "CursorPersistencePath": "jetstream-cursor.txt"
  },
  "Constellation": {
    "MaxNodeCount": 100,
    "NodeFadeWindowMinutes": 60
  },
  "Features": {
    "EnableDiagnosticTerminal": true
  },
  "Telemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "SimulationMode": {
    "Enabled": false
  }
}
