{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeyVault": {
    "Uri": "https://kv-poshared.vault.azure.net/"
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "AzureStorage": {
    "ConnectionString": ""
  },
  "AzureAI": {
    "Language": {
      "DailyApiCallCap": 3000
    }
  },
  "Jetstream": {
    "SentimentSampleRate": 10,
    "Anchors": [
      {
        "AnchorId": "Robotics",
        "Keywords": [ "robotics", "robot", "ROS2", "ROS", "robotic arm", "servo", "actuator" ]
      },
      {
        "AnchorId": "Reinforcement Learning",
        "Keywords": [ "reinforcement learning", "RL", "reward function", "policy gradient", "PPO", "DQN", "Q-learning", "RLHF" ]
      },
      {
        "AnchorId": "Neural Networks",
        "Keywords": [ "neural network", "deep learning", "transformer", "CNN", "LSTM", "backpropagation", "gradient descent", "PyTorch", "TensorFlow" ]
      },
      {
        "AnchorId": "Autonomy",
        "Keywords": [ "autonomous", "self-driving", "SLAM", "path planning", "obstacle avoidance", "autopilot" ]
      },
      {
        "AnchorId": "AI Agents",
        "Keywords": [ "AI agent", "ML-Agents", "LLM agent", "multi-agent", "agentic", "Isaac", "NVIDIA Isaac", "simulation" ]
      }
    ]
  },
  "Constellation": {
    "MaxNodeCount": 100,
    "NodeFadeWindowMinutes": 60
  }
}
