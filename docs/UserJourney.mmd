flowchart TD
    LAND["Landing Page\nConstellation renders immediately"]
    GUEST["Guest Mode\nRead-only live canvas"]
    AUTH_PROMPT["Auth Prompt\nFederated login optional"]
    AUTHED["Authenticated User\nFull interaction unlocked"]

    subgraph Explore["Explore Constellation"]
        BROWSE["Browse live node clusters"]
        NODE_CLICK["Click a SuperHub node"]
        INSIGHT["Insight panel opens\nSemantic roots + sentiment posts"]
        FOCUS_Q["Apply Focus Mode?\nIsolate anchor subgraph"]
        FOCUS["Focus Mode Active\nFiltered constellation view"]
        GHOST_Q["Enable Ghost Overlay?\nShort-term historical delta"]
        GHOST["Ghost layer rendered\nAnchor history visible"]
    end

    subgraph Capture["Capture + Export"]
        SNAP_CLICK["Trigger Snapshot"]
        META["Fetch export metadata\nGET /api/snapshot/export-metadata"]
        CLIENT_CAP["Client canvas capture\nHigh-res PNG"]
        DOWNLOAD["Download / Share artifact"]
    end

    subgraph Operate["Operational Surface"]
        DIAG["Open Diagnostic Dashboard"]
        HEALTH["Health check status\nGET /diagnostic/health"]
        CONFIG["Config visibility\nGET /diagnostic/config (masked)"]
        LOGS["Live log stream\nGET /diagnostic/logs"]
        UPTIME["Uptime analytics\nGET /diagnostic/uptime"]
    end

    LAND --> GUEST
    GUEST --> AUTH_PROMPT
    AUTH_PROMPT -->|Login| AUTHED
    AUTH_PROMPT -->|Skip| BROWSE
    AUTHED --> BROWSE

    BROWSE --> NODE_CLICK --> INSIGHT
    INSIGHT --> FOCUS_Q
    FOCUS_Q -->|Yes| FOCUS --> GHOST_Q
    FOCUS_Q -->|No| GHOST_Q
    GHOST_Q -->|Yes| GHOST --> SNAP_CLICK
    GHOST_Q -->|No| SNAP_CLICK

    SNAP_CLICK --> META --> CLIENT_CAP --> DOWNLOAD

    BROWSE --> DIAG
    DIAG --> HEALTH
    DIAG --> CONFIG
    DIAG --> LOGS
    DIAG --> UPTIME

