flowchart LR
    U["Research User"]

    subgraph Edge["Edge Delivery"]
        FD["Azure Front Door\nCDN · WAF · TLS"]
    end

    subgraph AppTier["Application Tier"]
        APP["PoLinks.Web\n.NET 10 API + React SPA"]
        HUB["SignalR PulseHub\n10-second broadcast"]
        WORKER["JetstreamWorker\nBackgroundService"]
        KV["Azure Key Vault\nManaged Identity + RBAC"]
    end

    subgraph DataTier["Data Tier"]
        SQL["Azure SQL Database\nRelational State"]
        REDIS["Azure Cache for Redis\nPulse Batch Cache"]
        TABLE["Azure Table Storage\nTime-Series Posts"]
    end

    subgraph Ext["External Providers"]
        JET["Bluesky Jetstream\nWebSocket Firehose"]
        BSKY["Bluesky REST API\nProfile Enrichment"]
    end

    U -->|HTTPS| FD
