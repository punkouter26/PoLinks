flowchart TB
    subgraph Ingestion["Ingestion Layer"]
        JET["Bluesky Jetstream\nWebSocket Firehose"]
        WORKER["JetstreamWorker\nBackgroundService"]
        ENRICH["LanguageSentimentService\n+ Bluesky REST Enrichment"]
    end

    subgraph Processing["Processing Layer"]
        HYPE["HypeScoreCalculator\nDecay-weighted frequency"]
        SENT["Sentiment Scoring\nNeg / Neutral / Pos"]
        CAP["NodeCapEnforcer\nMax-node eviction policy"]
        FOCUS["FocusSubgraphResolver\nAnchor-isolated subgraph"]
        GHOST["Ghost Overlay\nShort-term historical delta"]
        ROOTS["SemanticRootsResolver\nImpact-sorted post roots"]
    end

    subgraph Persistence["Persistence Layer"]
        SQL["Azure SQL\nAnchor · SuperHub · Link · Author · Post"]
        TABLE["Azure Table Storage\nDaily-partitioned raw posts"]
        REDIS["Redis\nPulse batch cache · Hype acceleration"]
    end

    subgraph Egress["Egress + UI Update"]
        PULSE["PulseService\n10-second assembly + fire"]
        HUB["SignalR PulseHub\nFan-out to all clients"]
        SNAP["SnapshotEndpoints\nExport metadata + client capture"]
        DIAG["DiagnosticEndpoints\nHealth · Config · Logs · Uptime"]
        UI["Constellation Canvas\nNode growth / decay / links"]
        INSIGHT["Insight Panel\nSentiment-coded post stream"]
    end

    JET -->|Raw post events| WORKER
    WORKER -->|Parse + batch| ENRICH
    ENRICH -->|Enriched posts| HYPE
    ENRICH -->|Language detection| SENT
    HYPE --> CAP
    CAP -->|Pruned constellation| SQL
    SENT -->|Sentiment labels| SQL
    ENRICH -->|Raw rows| TABLE
    CAP --> FOCUS
    FOCUS --> ROOTS
    CAP --> GHOST

    SQL --> REDIS
    REDIS --> PULSE
    PULSE -->|Batch payload| HUB
    HUB -->|SignalR push| UI
    UI --> INSIGHT
    UI --> SNAP
    UI --> DIAG

