flowchart TB
    subgraph Journey["User Journey + Auth"]
        START["User Opens PoLinks"]
        NAV["Front Door Routes Request"]
        APP["App Service Serves SPA"]
        AUTH["Auth Context Resolved\n(Guest or Federated)"]
        DASH["Dashboard Loaded"]
    end

    subgraph PulsePipeline["Realtime + Data Pipeline"]
        JET["Jetstream Events"]
        ENRICH["Follower Enrichment"]
        SCORE["Hype + Sentiment Scoring"]
        PULSE["Pulse Batch Assembly"]
        HUB["SignalR Pulse Hub"]
        UI["Canvas Re-render + Insight Panel"]
    end

    subgraph CrudFlow["Primary CRUD Processing"]
        CREATE["Create Focus Context"]
        READ["Read Insight + Diagnostic"]
        UPDATE["Update Focus/Filters"]
        EXPORT["Export Snapshot Metadata"]
        LOGS["Diagnostic Logs + Correlation IDs"]
    end

    START --> NAV --> APP --> AUTH --> DASH
    DASH --> READ
    DASH --> CREATE
    CREATE --> UPDATE
    UPDATE --> READ
    READ --> EXPORT
    READ --> LOGS

    JET --> ENRICH --> SCORE --> PULSE --> HUB --> UI
    UI --> READ

    style START fill:#0f172a,stroke:#38bdf8,color:#fff
    style NAV fill:#1e293b,stroke:#7dd3fc,color:#fff
