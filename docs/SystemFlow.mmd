        INSIGHT["Read Insight + Semantic Roots"]
        GHOST["Toggle Ghost Overlay"]
        EXPORT["Export Snapshot Metadata"]
        DIAG["Diagnostic Health · Config · Logs"]
        SIM["Simulation Mode\nReplay synthetic pulse"]
    end

    START --> FD --> SPA --> AUTH --> DASH
    DASH --> FOCUS
